# Bolig Norge — Environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Supabase project URL — found in Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — same place as URL above.
# This is safe to expose in the frontend; row-level security protects data.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
